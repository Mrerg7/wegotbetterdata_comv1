---
import { SITE, HERO_IMAGE_CDN } from '../consts';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  path = '/',
} = Astro.props;

const canonical = new URL(path, SITE.url).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    description,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: 'WeGotBetterData.com — Premium Domain Name',
    description: 'Premium digital asset positioned as the definitive independent index for AI data quality excellence. Category-defining .com domain available for strategic acquisition.',
    url: SITE.url,
    category: 'Domain Name',
    brand: {
      '@type': 'Brand',
      name: 'WeGotBetterData',
      slogan: 'We Got Better Data.',
    },
    offers: {
      '@type': 'Offer',
      url: SITE.url,
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      priceValidUntil: '2027-12-31',
      seller: {
        '@type': 'Organization',
        name: 'Desert Rich',
        email: SITE.acquisitionEmail,
      },
      hasMerchantReturnPolicy: {
        '@type': 'MerchantReturnPolicy',
        returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
        returnMethod: 'https://schema.org/ReturnByMail',
        applicableCountry: 'US',
      },
      shippingDetails: {
        '@type': 'OfferShippingDetails',
        shippingRate: {
          '@type': 'MonetaryAmount',
          value: 0,
          currency: 'USD',
        },
        deliveryTime: {
          '@type': 'ShippingDeliveryTime',
          handlingTime: {
            '@type': 'QuantitativeValue',
            minValue: 1,
            maxValue: 3,
            unitCode: 'd',
          },
          transitTime: {
            '@type': 'QuantitativeValue',
            minValue: 0,
            maxValue: 0,
            unitCode: 'd',
          },
        },
        shippingDestination: {
          '@type': 'DefinedRegion',
          addressCountry: 'US',
        },
      },
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5',
      bestRating: '5',
      ratingCount: 1,
    },
    review: {
      '@type': 'Review',
      author: {
        '@type': 'Organization',
        name: 'WeGotBetterData.com',
      },
      reviewBody:
        'Premium domain for AI data quality indexing — a category-defining digital asset for the era of data-driven AI adoption.',
    },
    image: HERO_IMAGE_CDN,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'WeGotBetterData.com',
    url: SITE.url,
    logo: HERO_IMAGE_CDN,
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: SITE.acquisitionEmail,
      availableLanguage: 'English',
    },
  },
];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="canonical" href={canonical} />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<meta name="author" content="WeGotBetterData.com" />
<meta name="theme-color" content="#050914" />
<meta name="google-site-verification" content="c_NA5R-59RaQMkU34B_x7R-af0gZYuSViu-SwNWlU9M" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:image" content={HERO_IMAGE_CDN} />
<meta property="og:image:secure_url" content={HERO_IMAGE_CDN} />
<meta property="og:image:alt" content="WeGotBetterData.com — The Definitive Index for AI Data Excellence" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={HERO_IMAGE_CDN} />
<meta name="twitter:image:alt" content="WeGotBetterData.com — The Definitive Index for AI Data Excellence" />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="preconnect" href="https://imagedelivery.net" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
