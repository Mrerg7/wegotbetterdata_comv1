---
import { ACQUISITION_MAILTO } from '../consts';
---

<nav class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="mx-auto max-w-screen-xl px-6 h-20 flex items-center justify-between">
    <div class="flex items-center gap-x-3">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-sky-400 to-cyan-500 flex items-center justify-center">
        <span class="text-[#050914] font-bold text-lg tracking-tighter">WD</span>
      </div>
      <div>
        <div class="font-semibold tracking-[2px] text-sm">WEGOTBETTERDATA</div>
        <div class="text-[10px] text-sky-400/60 -mt-1 tracking-wider">.COM</div>
      </div>
    </div>

    <div class="hidden md:flex items-center gap-x-8 text-sm tracking-widest text-slate-400">
      <a href="#problem" class="hover:text-sky-300 transition-colors">THE PROBLEM</a>
      <a href="#opportunity" class="hover:text-sky-300 transition-colors">THE OPPORTUNITY</a>
      <a href="#platform" class="hover:text-sky-300 transition-colors">THE PLATFORM</a>
      <a href="#value" class="hover:text-sky-300 transition-colors">THE VALUE</a>
    </div>

    <a
      href={ACQUISITION_MAILTO}
      class="hidden md:inline-flex items-center gap-x-2 px-6 py-2.5 text-xs tracking-[2px] border border-sky-400/40 text-sky-300 hover:bg-sky-400/10 hover:border-sky-400 transition-all rounded-full font-semibold"
    >
      INQUIRE
      <span class="text-base">↗</span>
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-sky-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>
